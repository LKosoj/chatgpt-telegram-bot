# Your OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# Your Telegram bot token obtained using @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram user ID of admins, or - to assign no admin
ADMIN_USER_IDS=ADMIN_1_USER_ID,ADMIN_2_USER_ID

# Comma separated list of telegram user IDs, or * to allow all
ALLOWED_TELEGRAM_USER_IDS=USER_ID_1,USER_ID_2

# Optional configuration, refer to the README for more details
# BUDGET_PERIOD=monthly
# USER_BUDGETS=*
# GUEST_BUDGET=100.0
# TOKEN_PRICE=0.002
# IMAGE_PRICES=0.016,0.018,0.02
# TRANSCRIPTION_PRICE=0.006
# VISION_TOKEN_PRICE=0.01
# ENABLE_QUOTING=true
# ENABLE_IMAGE_GENERATION=true
# ENABLE_TTS_GENERATION=true
# ENABLE_TRANSCRIPTION=true
# ENABLE_VISION=true
# PROXY=http://localhost:8080

OPENAI_MODEL=llmgateway/high
BIG_MODEL_TO_USE=llmgateway/big_context
LIGHT_MODEL=llmgateway/light_model
# OPENAI_BASE_URL=https://example.com/v1/
# ASSISTANT_PROMPT="You are a helpful assistant."
# SHOW_USAGE=false
STREAM=false
# TELEGRAM_LOCAL_MODE=true
# TELEGRAM_BASE_URL=http://localhost:8081/bot
# MAX_TOKENS=1200
# VISION_MAX_TOKENS=1000
MAX_HISTORY_SIZE=50
MAX_CONVERSATION_AGE_MINUTES=18000
AUTO_CHAT_MODES=true
# VOICE_REPLY_WITH_TRANSCRIPT_ONLY=true
# VOICE_REPLY_PROMPTS="Hi bot;Hey bot;Hi chat;Hey chat"
# VISION_PROMPT="What is in this image"
# N_CHOICES=1
# TEMPERATURE=1.0
# PRESENCE_PENALTY=0.0
# FREQUENCY_PENALTY=0.0
# IMAGE_MODEL=dall-e-3
# IMAGE_QUALITY=hd
# IMAGE_STYLE=natural
# IMAGE_SIZE=1024x1024
# IMAGE_FORMAT=document
# VISION_DETAIL="low"
# GROUP_TRIGGER_KEYWORD=""
# IGNORE_GROUP_TRANSCRIPTIONS=true
# IGNORE_GROUP_VISION=true
# TTS_MODEL="llmgateway/silero-tts"
# TTS_VOICE="kseniya"
# TTS_PRICES=0.015,0.030
BOT_LANGUAGE=en
# ENABLE_VISION_FOLLOW_UP_QUESTIONS="true"
# VISION_MODEL="gpt-4-vision-preview"

# Leave PLUGINS unset or empty to load every plugin from bot/plugins.
# Set PLUGINS to a comma-separated allow-list only when you want to restrict plugins.
# PLUGINS=ddg_web_search,web_research,agent_tools,skills
SHOW_PLUGINS_USED=true

# ANYTHINGLLM_BASE_URL=http://anythingllm.example/api
# ANYTHINGLLM_API_KEY=your_anythingllm_api_key
# ANYTHINGLLM_WORKSPACE_PREFIX=telegram-chat
# ANYTHINGLLM_CHAT_MODE=query
# ANYTHINGLLM_VECTOR_SEARCH_MODE=rerank
# ANYTHINGLLM_TOP_N=6
# ANYTHINGLLM_SIMILARITY_THRESHOLD=0.25
# WOLFRAM_APP_ID=XXX
# WORLDTIME_DEFAULT_TIMEZONE=Europe/Moscow
# STABLE_DIFFUSION_TOKEN=XXX
# DEEPL_API_KEY=XXX
# TMDB_API_KEY=your_tmdb_api_key
# YANDEX_API_TOKEN=your_yandex_api_token
# MAX_SESSIONS=5
# EDAMAM_APP_ID=your_edamam_app_id
# EDAMAM_APP_KEY=your_edamam_app_key
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key
# ENABLE_LOCAL_FILE_SERVER=true
# LOCAL_FILE_SERVER_HOST=localhost
# LOCAL_FILE_SERVER_PORT=18080
# TELEGRAM_DOWNLOAD_BOT_ID=your_download_bot_id
# TELEGRAM_DOWNLOAD_DIR=path/to/download/dir

# MCP Server Configuration
# ENABLE_MCP_SERVERS=true
# MCP_SERVERS_ALLOWED_USERS=*
# DEFAULT_MCP_SERVERS=weather:http://localhost:8080,finance:http://localhost:8081
# MCP_REQUEST_TIMEOUT=30

# Skills plugin (Codex-style local skills exposed as tools)
# SKILLS_DIR=/absolute/path/to/skills      # default: <storage_root>/skills
# SKILLS_ALLOW_SCRIPTS=false               # set true to enable skills.run_skill_script
# SKILLS_SCRIPT_ADMIN_USER_IDS=USER_ID_1,USER_ID_2  # comma list, or *
# SKILLS_ALLOW_INSTALLS=true               # set false to disable skills.install_skill
# SKILLS_INSTALL_ADMIN_USER_IDS=*          # comma list of allowed user IDs, or * for everyone
# SKILLS_INSTALL_TIMEOUT=180               # seconds for npx skills find/add
# SKILLS_SCRIPT_TIMEOUT=120                # seconds
# SKILLS_SCRIPT_OUTPUT_MAX_CHARS=12000

# Agent tools plugin
# Seconds the agent waits for a Telegram answer.
AGENT_ASK_USER_TIMEOUT_SECONDS=1800

# Hindsight long-term memory. Enabled automatically when HINDSIGHT_API_TOKEN is set.
# HINDSIGHT_BASE_URL=http://example.com/hindsight
# HINDSIGHT_API_TOKEN=your_hindsight_token
# HINDSIGHT_AUTO_RECALL=true
# HINDSIGHT_AUTO_SAVE=true
# HINDSIGHT_RECALL_BUDGET=mid
# HINDSIGHT_RECALL_MAX_TOKENS=4096
# HINDSIGHT_MEMORY_TYPES=world,experience
# HINDSIGHT_ASYNC_STORE=true
